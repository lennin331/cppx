#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' 

CXX_STANDARD="17"
show_usage() {
    echo -e "${YELLOW}Usage:${NC}"
    echo "  cppx filename.cpp                          - Compile and run (interactive)"
    echo "  cppx -cp filename.cpp input.txt            - Use input.txt, output to output.txt "
    echo "  cppx -cp --11 filename.cpp input.txt       - Use C++11 standard"
    echo "  cppx -cp --14 filename.cpp input.txt       - Use C++14 standard"
    echo "  cppx -cp --17 filename.cpp input.txt       - Use C++17 standard"
    echo "  cppx -cp --20 filename.cpp input.txt       - Use C++20 standard"
    echo "  cppx -cp --23 filename.cpp input.txt       - Use C++23 standard"
    echo ""
    echo -e "${BLUE}Note:${NC} Output always goes to output.txt (overwrites existing)"
}
get_base_filename() {
    local cpp_file="$1"
    echo "${cpp_file%.*}"
}
parse_standard() {
    case "$1" in
        --11|--c++11) echo "11" ;;
        --14|--c++14) echo "14" ;;
        --17|--c++17) echo "17" ;;
        --20|--c++20) echo "20" ;;
        --23|--c++23) echo "23" ;;
        *) echo "$CXX_STANDARD" ;;
    esac
}
if [ $# -eq 0 ]; then
    show_usage
    exit 1
fi
if [ "$1" == "-cp" ]; then
    shift  
   
    if [[ "$1" =~ ^--(11|14|17|20|23|c\+\+(11|14|17|20|23))$ ]]; then
        CXX_STANDARD=$(parse_standard "$1")
        shift
    fi
    
    
    if [ $# -lt 2 ]; then
        echo -e "${RED}Error: Missing filename or input file${NC}"
        echo -e "${YELLOW}Usage: cppx -cp filename.cpp input.txt${NC}"
        exit 1
    fi
    
    cpp_file="$1"
    input_file="$2"
    output_file="output.txt"
    

    if [ ! -f "$cpp_file" ]; then
        echo -e "${RED}Error: File '$cpp_file' not found${NC}"
        exit 1
    fi
    

    if [ ! -f "$input_file" ]; then
        echo -e "${RED}Error: Input file '$input_file' not found${NC}"
        exit 1
    fi
    

    base_name=$(get_base_filename "$cpp_file")
    executable="${base_name}"

    echo -e "${YELLOW}Compiling $cpp_file with C++${CXX_STANDARD}...${NC}"
    g++ "-std=c++${CXX_STANDARD}" "$cpp_file" -o "$executable"
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}compilation successful${NC}"
        echo -e "${YELLOW}running - input - '${input_file}'...${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        
        ./"$executable" < "$input_file" > "$output_file"
        
        if [ $? -eq 0 ]; then
            echo -e "${GREEN} execution completed${NC}"
            echo -e "${GREEN} Output @ ${output_file} (overwritten)${NC}"
            echo ""
            echo -e "${YELLOW}--- Output Preview ---${NC}"
            echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            cat "$output_file"
            echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        else
            echo -e "${RED}execution failed${NC}"
        fi
    else
        echo -e "${RED}compilation failed${NC}"
    fi
 Regular compilation and run (no -cp flag) - interactive mode
else
    cpp_file="$1"
    

    if [[ "$cpp_file" =~ ^--(11|14|17|20|23) ]]; then
        CXX_STANDARD=$(parse_standard "$cpp_file")
        shift
        cpp_file="$1"
    fi
    
    if [ ! -f "$cpp_file" ]; then
        echo -e "${RED}Error: File '$cpp_file' not found${NC}"
        exit 1
    fi
    
    base_name=$(get_base_filename "$cpp_file")
    executable="${base_name}"
    
    echo -e "${YELLOW}Compiling $cpp_file with C++${CXX_STANDARD}...${NC}"
    g++ "-std=c++${CXX_STANDARD}" "$cpp_file" -o "$executable"
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}compiled${NC}"
	echo -e "${YELLOW}executed - waiting input (enter)${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        ./"$executable"
    else
        echo -e "${RED}compilation failed${NC}"
    fi
fi
